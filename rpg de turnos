jogador = {
    "moedas": 300,
    "pocoes": 0,
    "vida": 100,
    "vida_vilao": 130
}
def comprar_pocao(dados, preco):
    if dados["moedas"] >=preco:
        dados["moedas"] -=preco
        dados["pocoes"] +=1
        print("você comprou uma poção")
        return True
    else:
        print("você não tem moedas o suficiente")
        return False
    
def usar_pocao(dados):
    if dados["pocoes"] >0:
        dados["pocoes"] -=1
        dados["vida"] +=50
        print("você usou uma poção, sua vida recuperou 50 pontos")

    else:
        print("você não tem poções o suficiente")

while True:
